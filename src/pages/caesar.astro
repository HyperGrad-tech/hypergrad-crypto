---
import ToolLayout from '../layouts/ToolLayout.astro';
import CaesarCipher from '../components/tools/CaesarCipher.tsx';
---
<ToolLayout slug="caesar">
  <CaesarCipher client:load />
  <div slot="seo-content">
    <h2>凯撒密码在线工具</h2>
    <p>
      凯撒密码（Caesar Cipher）是人类历史上最早的加密方法之一，相传由罗马皇帝尤利乌斯·凯撒用于军事通信。
      原理极简：将英文字母按字母表向后位移固定数量的位置（凯撒本人用位移 3）。例如位移 3 时，A→D、B→E、Z→C。
      本工具支持自定义位移、爆破所有 26 种位移（用于破解未知密文）、ROT13 特殊模式。
    </p>
    <h3>位移模式</h3>
    <ul>
      <li><strong>凯撒 3</strong>：原始凯撒使用的位移，A→D、B→E。</li>
      <li><strong>ROT13</strong>：位移 13，由于英文字母 26 个，ROT13 加密 = 解密（自反），是 Usenet 早期用于隐藏剧透、谜底的常见做法。</li>
      <li><strong>自定义位移</strong>：0-25 任意位移。</li>
      <li><strong>爆破模式</strong>：列出 26 种位移结果，用于解密未知位移的密文。</li>
    </ul>
    <h3>为什么凯撒密码不安全？</h3>
    <ul>
      <li><strong>密钥空间极小</strong>：只有 25 种有效位移，暴力破解瞬间完成。</li>
      <li><strong>字母频率不变</strong>：英文中 E 最常见，密文中 E 对应的字符也最常见，频率分析可破解。</li>
      <li><strong>无密钥也能猜</strong>：人类语言有模式，爆破时哪个位移读起来像正常文本就是答案。</li>
    </ul>
    <h3>常见应用</h3>
    <ul>
      <li><strong>教学</strong>：密码学入门必讲，理解"加密"和"哈希"区别。</li>
      <li><strong>CTF</strong>：Capture The Flag 安全竞赛的入门题。</li>
      <li><strong>娱乐</strong>：朋友间的简单暗号、谜语。</li>
      <li><strong>ROT13</strong>：网络论坛隐藏答案、剧透。</li>
    </ul>
  </div>
</ToolLayout>
